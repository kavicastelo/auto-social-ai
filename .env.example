# =============================================================================
# Auto Social AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auto_social_ai?schema=public"

# ── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL="add-your-redis-host-url"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST="0.0.0.0"
SERVER_PORT=3001
NODE_ENV="development"

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
