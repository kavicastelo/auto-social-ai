# =============================================================================
# CreatorGene — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="add-your-database-url"

# ── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL="add-your-redis-host-url"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST="0.0.0.0"
SERVER_PORT=3001
NODE_ENV="development"

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="add-your-openai-api-key"

# ── OAuth (Replace these with your actual keys) ──────────────────────────────
TWITTER_CLIENT_ID="your_twitter_id"
TWITTER_CLIENT_SECRET="your_twitter_secret"
LINKEDIN_CLIENT_ID="your_linkedin_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_secret"
FACEBOOK_CLIENT_ID="your_facebook_id"
FACEBOOK_CLIENT_SECRET="your_facebook_secret"
INSTAGRAM_CLIENT_ID="your_instagram_id"
INSTAGRAM_CLIENT_SECRET="your_instagram_secret"
GOOGLE_CLIENT_ID="your_google_id"
GOOGLE_CLIENT_SECRET="your_google_secret"
TIKTOK_CLIENT_ID="your_tiktok_id"
TIKTOK_CLIENT_SECRET="your_tiktok_secret"

# ── Server URL for callbacks ────────────────────────────────────────────────────
SERVER_URL="http://localhost:3001"

# ── s3  ─────────────────────────────────────────────────────────────────────────
S3_REGION="auto"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_PUBLIC_DOMAIN=""
